  bx(g,1.58,0.06,0.72,0,0.46,0.56,bod,0.48);
  bx(g,1.52,0.04,0.70,0,0.50,-0.55,matGlass(),-0.52);
  bx(g,1.52,0.04,0.70,0,0.44,0.56,matGlass(),0.50);
  bx(g,0.04,0.22,0.88,0.84,0.28,0.02,matGlass());
  bx(g,0.04,0.22,0.88,-0.84,0.28,0.02,matGlass());
  bx(g,0.56,0.07,0.92,0,0.04,-1.02,matDark());
  bx(g,0.19,0.017,1.60,0,-0.02,-0.74,M(B.red,{metalness:0.5,roughness:0.3}));
  bx(g,0.19,0.017,1.40,0,-0.02,0.90,M(B.red,{metalness:0.5,roughness:0.3}));
  bx(g,0.19,0.045,1.48,0,0.345,0.04,M(B.red,{metalness:0.5,roughness:0.3}));
  bx(g,1.58,0.14,0.12,0,-0.22,-2.01,matChrome());
  bx(g,0.40,0.17,0.10,0.60,0.0,-1.98,matDark());
  bx(g,0.40,0.17,0.10,-0.60,0.0,-1.98,matDark());
  bx(g,0.32,0.11,0.06,0.60,0.0,-2.04,matLight());
  bx(g,0.32,0.11,0.06,-0.60,0.0,-2.04,matLight());
  bx(g,0.38,0.15,0.08,0.66,-0.06,2.05,matTail());
  bx(g,0.38,0.15,0.08,-0.66,-0.06,2.05,matTail());
  bx(g,1.58,0.10,0.10,0,-0.22,2.05,matChrome());
  cy(g,0.050,0.050,1.45,10,0.97,-0.29,-0.12,matChrome());
  cy(g,0.050,0.050,1.45,10,-0.97,-0.29,-0.12,matChrome());
  cy(g,0.038,0.038,1.45,8,0.97,-0.29,-0.12,matDark());
  cy(g,0.038,0.038,1.45,8,-0.97,-0.29,-0.12,matDark());
  bx(g,0.15,0.20,0.68,0.94,-0.15,-1.12,bod);
  bx(g,0.15,0.20,0.68,-0.94,-0.15,-1.12,bod);
  bx(g,0.15,0.20,0.68,0.94,-0.15,1.14,bod);
  bx(g,0.15,0.20,0.68,-0.94,-0.15,1.14,bod);
  bx(g,1.52,0.06,3.90,0,-0.45,0,matDark());
  wheel(g,0.89,-1.24);wheel(g,-0.89,-1.24);
  wheel(g,0.92,1.22);wheel(g,-0.92,1.22);
  const fl=new THREE.Mesh(new THREE.CircleGeometry(2.5,56),M("#040404",{metalness:0.88,roughness:0.22}));
  fl.rotation.x=-Math.PI/2;fl.position.y=-0.52;fl.receiveShadow=true;g.add(fl);
