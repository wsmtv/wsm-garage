  const fl=new THREE.Mesh(new THREE.CircleGeometry(2.5,56),M("#040404",{metalness:0.88,roughness:0.22}));
  fl.rotation.x=-Math.PI/2;fl.position.y=-0.54;fl.receiveShadow=true;g.add(fl);
