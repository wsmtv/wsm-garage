// ─── MATERIAL HELPERS ─────────────────────────────────────────────────────────
const M  = (hex, o={}) => new THREE.MeshStandardMaterial({ color: new THREE.Color(hex), ...o });
const bodyBlack = () => M("#0d0d0d", { metalness:0.88, roughness:0.16 });
const bodyRed   = () => M("#CC1800", { metalness:0.75, roughness:0.22 });
const matWhite  = () => M("#ffffff", { metalness:0.4,  roughness:0.3  });
const matChrome = () => M("#bbbbbb", { metalness:1.0,  roughness:0.08 });
const matDark   = () => M("#050505", { metalness:0.2,  roughness:0.9  });
const matGlass  = () => M("#88bbdd", { metalness:0.05, roughness:0.05, transparent:true, opacity:0.42 });
const matTire   = () => M("#0a0a0a", { metalness:0.05, roughness:0.95 });
const matRim    = () => M("#aaaaaa", { metalness:0.92, roughness:0.12 });
const matLight  = () => M("#ffffcc", { emissive:new THREE.Color("#ffee88"), emissiveIntensity:0.55 });
const matTail   = () => M("#dd1100", { emissive:new THREE.Color("#aa0000"), emissiveIntensity:0.85 });

function bx(g,w,h,d,x,y,z,mat,rx=0,ry=0,rz=0){
  const m=new THREE.Mesh(new THREE.BoxGeometry(w,h,d),mat);
  m.position.set(x,y,z);m.rotation.set(rx,ry,rz);m.castShadow=true;g.add(m);
}
function cy(g,rt,rb,h,sg,x,y,z,mat,rx=Math.PI/2){
  const m=new THREE.Mesh(new THREE.CylinderGeometry(rt,rb,h,sg),mat);
  m.position.set(x,y,z);m.rotation.x=rx;m.castShadow=true;g.add(m);
}
function wheel(g,x,z){
  cy(g,0.30,0.30,0.21,22,x,-0.36,z,matTire());
  cy(g,0.20,0.20,0.22,14,x,-0.36,z,matRim());
  cy(g,0.08,0.08,0.23, 8,x,-0.36,z,matDark());
  cy(g,0.025,0.025,0.24,6,x,-0.36,z,matChrome());
}

